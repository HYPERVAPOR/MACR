# OpenAI API configuration
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# OPENAI_MODEL=o3-mini

# Optional: base URL for proxies or Azure OpenAI
# OPENAI_BASE_URL=https://api.openai.com/v1

# Set to false when using OpenAI-compatible providers that do not support
# the beta chat.completions.parse endpoint (e.g. vLLM, Ollama, some proxies).
OPENAI_USE_BETA_PARSE=true

# MACR runtime configuration
MACR_MAX_REPAIR_ATTEMPTS=3
MACR_MAX_TOKENS=4096
MACR_TEMPERATURE=0.2

# Logging
MACR_LOG_LEVEL=INFO
