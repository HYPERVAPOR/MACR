	url = {http://ieeexplore.ieee.org/document/6606626/},
	doi = {10.1109/ICSE.2013.6606626},
	abstract = {Patch generation is an essential software maintenance task because most software systems inevitably have bugs that need to be ﬁxed. Unfortunately, human resources are often insufﬁcient to ﬁx all reported and known bugs. To address this issue, several automated patch generation techniques have been proposed. In particular, a genetic-programming-based patch generation technique, {GenProg}, proposed by Weimer et al., has shown promising results. However, these techniques can generate nonsensical patches due to the randomness of their mutation operations.},
	eventtitle = {2013 35th International Conference on Software Engineering ({ICSE})},
	pages = {802--811},
	booktitle = {2013 35th International Conference on Software Engineering ({ICSE})},
	publisher = {{IEEE}},
	author = {Kim, Dongsun and Nam, Jaechang and Song, Jaewoo and Kim, Sunghun},
